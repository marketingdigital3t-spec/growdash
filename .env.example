# Front-end public environment variables
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Supabase Edge Function secrets
# Configure these in Supabase Dashboard > Project Settings > Edge Functions > Secrets.
# Do not expose service role keys or provider API tokens in Vite variables.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
LOVABLE_API_KEY="your-lovable-ai-key"

# Provider/API tokens must be stored server-side only.
# Meta/RD/WhatsApp tokens should be saved through secure backend flows,
# preferably encrypted or stored with Supabase Vault.
